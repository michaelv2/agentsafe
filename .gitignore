# =============================================================================
# SECRETS — NEVER commit these
# =============================================================================
config/.credentials.json
config/git-credentials
config/authorized_keys
config/.env

# Catch-all for future secrets in config/
config/*.pem
config/*.pub
config/id_*
config/*secret*

# =============================================================================
# WORKSPACE — user data, not part of the project
# =============================================================================
workspace/

# =============================================================================
# Machine-specific files
# =============================================================================
.claude/settings.local.json
docker-compose.yml
SANDBOX.md
CLAUDE.md

# =============================================================================
# OS and editor artifacts
# =============================================================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# =============================================================================
# Python artifacts
# =============================================================================
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# =============================================================================
# Node artifacts
# =============================================================================
node_modules/

# =============================================================================
# Logs and databases
# =============================================================================
*.log
*.db
*.sqlite
*.sqlite3
